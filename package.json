{
	"name": "agora-monorepo",
	"version": "0.0.1",
	"private": true,
	"scripts": {
		"dev:engine": "cd apps/engine && uv run uvicorn main:app --reload --port 8000",
		"dev:arena": "cd apps/arena && bun run dev",
		"dev": "concurrently \"bun run dev:engine\" \"bun run dev:arena\""
	},
	"devDependencies": {
		"concurrently": "^9.2.1"
	}
}
